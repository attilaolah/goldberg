# EditorConfig: https://editorconfig.org
[*]
charset = utf-8

end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

indent_size = 2
rulers = [120,220]
max_line_length = 120
quote_type = double

[*.md]
max_line_length = off

[*.{css,html,js,mjs,mts,sass,scss,ts,tsx,xml}]
max_line_length = 220
